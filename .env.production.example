APP_ENV=production
APP_VERSION=1.0.0
BASE_URL=https://your-render-service.onrender.com
SECRET_KEY=replace-with-a-long-random-secret

# Supabase session pooler (copy DIRECT_URL from Connect → ORM → .env.local)
# Change postgresql:// to postgresql+asyncpg:// and percent-encode @ in password
DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:password@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Upstash Redis (use rediss:// for TLS)
REDIS_URL=rediss://default:password@your-upstash-endpoint.upstash.io:6379

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

CACHE_TTL_SECONDS=3600
NEGATIVE_CACHE_TTL_SECONDS=300

SHORT_CODE_LENGTH=6
SHORT_CODE_MAX_RETRIES=5
