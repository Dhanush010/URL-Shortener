APP_ENV=production
APP_VERSION=1.0.0
BASE_URL=https://your-render-service.onrender.com
SECRET_KEY=replace-with-a-long-random-secret

# Supabase Postgres (convert postgresql:// to postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Upstash Redis (use rediss:// for TLS)
REDIS_URL=rediss://default:password@your-upstash-endpoint.upstash.io:6379

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

CACHE_TTL_SECONDS=3600
NEGATIVE_CACHE_TTL_SECONDS=300

SHORT_CODE_LENGTH=6
SHORT_CODE_MAX_RETRIES=5
